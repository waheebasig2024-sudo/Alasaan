# Gemini API keys - get from https://aistudio.google.com/app/apikey
# These get embedded into the app at build time via app.config.js
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=

# Optional: model override
GEMINI_MODEL=gemini-2.5-flash

# Optional: API server domain (for proxy fallback in dev)
EXPO_PUBLIC_DOMAIN=
