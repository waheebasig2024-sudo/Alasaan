{
  "expo": {
    "name": "الحسن المساعد الشخصي الذكي",
    "slug": "alahsan",
    "description": "الحسن مساعد عربي ذكي للأندرويد، تمت برمجته وتطويره بواسطة وهيب عساج.",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "al-hassan",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F1A"
    },
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#0B0F1A"
    },
    "androidNavigationBar": {
      "backgroundColor": "#0B0F1A"
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "minSdkVersion": 28,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B0F1A"
      },
      "package": "com.alhassan.assistant",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.CALL_PHONE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.WAKE_LOCK",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      "expo-updates",
      [
        "expo-contacts",
        {
          "contactsPermission": "السماح للحسن بالوصول إلى جهات الاتصال لتنفيذ أوامر الاتصال والمراسلة"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "السماح للحسن بالوصول إلى التقويم لإضافة المواعيد"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "السماح للحسن بالتحقق من هويتك"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "السماح للحسن بالوصول إلى الصور",
          "cameraPermission": "السماح للحسن باستخدام الكاميرا"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "السماح للحسن بالوصول إلى مكتبة الصور",
          "savePhotosPermission": "السماح للحسن بحفظ الصور"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "geminiKeys": [],
      "geminiModel": "gemini-2.0-flash",
      "apiDomain": "alasan-sudo--arydan33.replit.app",
      "eas": {
        "projectId": "3bddef58-e3dc-47f7-9f3f-f6349e0d1908"
      }
    },
    "owner": "waheebasig",
    "updates": {
      "url": "https://u.expo.dev/3bddef58-e3dc-47f7-9f3f-f6349e0d1908",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    }
  }
}